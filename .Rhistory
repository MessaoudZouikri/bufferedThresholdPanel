t_value = round(t_value, 3),
p_value = round(p_value, 4)
),
caption = "Quantile Regression Interaction Effects",
col.names = c("Predictor", "Coefficient", "Std. Error", "t value", "p-value"),
align = "lrrrr",
booktabs = TRUE)
# First, make sure quantile_results exists or create it
# This line was likely missing in the original code
quantile_results <- data.frame()  # Define or compute this based on your analysis needs
# Visualize the quantile regression results
if(nrow(quantile_results) > 0) {  # Only run if quantile_results has data
ggplot(quantile_results, aes(x = tau, y = Coefficient, color = Predictor)) +
geom_line(size = 1) +
geom_ribbon(aes(ymin = Coefficient - 1.96 * StdError,
ymax = Coefficient + 1.96 * StdError,
fill = Predictor),
alpha = 0.2, linetype = "dashed") +
theme_minimal() +
labs(title = "Quantile Regression Coefficients Across Quantiles",
x = "Quantile (Ď„)",
y = "Coefficient Estimate") +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray50") +
scale_color_brewer(palette = "Set1") +
scale_fill_brewer(palette = "Set1")
}
# Make sure my_formula and analysis_data are defined
# These were likely missing in the original code
my_formula <- sales_growth2 ~ bribe_hat + size + age + manuf_d + export_d + topman_exp + informal
# Compare with OLS regression
if(exists("analysis_data")) {  # Only run if analysis_data exists
ols_model <- lm(formula = my_formula, data = analysis_data)
ols_summary <- summary(ols_model)
# Create table of OLS results
ols_results <- tibble(
Predictor = names(coef(ols_model)),
Coefficient = coef(ols_model),
StdError = sqrt(diag(vcov(ols_model))),
t = Coefficient / StdError,
`p-value` = 2 * pt(abs(t), df = ols_model$df.residual, lower.tail = FALSE)
)
# Display OLS results
kable(ols_results %>%
mutate(
Coefficient = round(Coefficient, 4),
StdError = round(StdError, 4),
t = round(t, 3),
`p-value` = round(`p-value`, 4)
),
caption = "OLS Regression Results",
col.names = c("Predictor", "Coefficient", "Std. Error", "t value", "p-value"),
align = "lrrrr",
booktabs = TRUE)
# Calculate and display quantile effects at specific quantiles of interest
tau_values <- c(0.1, 0.25, 0.5, 0.75, 0.9)
specific_quantiles <- data.frame()
for (tau in tau_values) {
model_q <- rq(formula = my_formula, tau = tau, data = analysis_data)
coef_q <- coef(model_q)
se_q <- summary(model_q, se = "nid")$coefficients[, 2]
temp_df <- tibble(
Quantile = tau,
Predictor = names(coef_q),
Coefficient = coef_q,
StdError = se_q,
LowerCI = Coefficient - 1.96 * StdError,
UpperCI = Coefficient + 1.96 * StdError
)
specific_quantiles <- bind_rows(specific_quantiles, temp_df)
}
# Display specific quantile results
kable(specific_quantiles %>%
mutate(
Coefficient = round(Coefficient, 4),
StdError = round(StdError, 4),
LowerCI = round(LowerCI, 4),
UpperCI = round(UpperCI, 4)
),
caption = "Quantile Regression Results at Specific Quantiles",
col.names = c("Quantile", "Predictor", "Coefficient", "Std. Error", "Lower 95% CI", "Upper 95% CI"),
align = "crrrr",  # Corrected number of alignment values to match columns
booktabs = TRUE)
# Plot specific quantile effects with confidence intervals
ggplot(specific_quantiles, aes(x = factor(Quantile), y = Coefficient, color = Predictor)) +
geom_point(position = position_dodge(width = 0.3), size = 3) +
geom_errorbar(aes(ymin = LowerCI, ymax = UpperCI),
position = position_dodge(width = 0.3), width = 0.2) +
theme_minimal() +
labs(title = "Coefficient Estimates at Key Quantiles",
x = "Quantile (Ď„)",
y = "Coefficient Estimate") +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray50") +
scale_color_brewer(palette = "Set1") +
facet_wrap(~ Predictor, scales = "free_y", ncol = 2)
# Calculate goodness of fit measures
fit_measures <- data.frame(
Quantile = tau_values,
Pseudo_R2 = numeric(length(tau_values))
)
for (i in 1:length(tau_values)) {
tau <- tau_values[i]
model_q <- rq(formula = my_formula, tau = tau, data = analysis_data)
model_null <- rq(formula = update(my_formula, . ~ 1), tau = tau, data = analysis_data)
# Calculate pseudo RÂ˛ (1 - residual sum / null model sum)
residual_sum <- sum(abs(model_q$residuals) * (tau * (model_q$residuals >= 0) +
(1 - tau) * (model_q$residuals < 0)))
null_sum <- sum(abs(model_null$residuals) * (tau * (model_null$residuals >= 0) +
(1 - tau) * (model_null$residuals < 0)))
fit_measures$Pseudo_R2[i] <- 1 - residual_sum / null_sum
}
# Display goodness of fit measures
kable(fit_measures %>%
mutate(Pseudo_R2 = round(Pseudo_R2, 4)),
caption = "Pseudo RÂ˛ at Different Quantiles",
col.names = c("Quantile (Ď„)", "Pseudo RÂ˛"),
align = "cr",
booktabs = TRUE)
# Diagnostic plots
# Create residual plots for the median regression
median_model <- rq(formula = my_formula, tau = 0.5, data = analysis_data)
fitted_values <- fitted(median_model)
residuals <- residuals(median_model)
# Residuals vs Fitted plot
residual_data <- tibble(
Fitted = fitted_values,
Residuals = residuals
)
ggplot(residual_data, aes(x = Fitted, y = Residuals)) +
geom_point(alpha = 0.5) +
geom_hline(yintercept = 0, linetype = "dashed", color = "red") +
geom_smooth(method = "loess", se = FALSE, color = "blue") +
theme_minimal() +
labs(title = "Residuals vs Fitted Values (Median Regression)",
x = "Fitted Values",
y = "Residuals")
# QQ plot of residuals
ggplot(residual_data, aes(sample = Residuals)) +
stat_qq() +
stat_qq_line() +
theme_minimal() +
labs(title = "Q-Q Plot of Residuals (Median Regression)",
x = "Theoretical Quantiles",
y = "Sample Quantiles")
}
# Conclusion and summary of findings
cat("## Summary of Findings\n\n")
cat("This analysis employed quantile regression to examine the relationship between the outcome variable and predictors across different points of the conditional distribution. The key findings include:\n\n")
cat("1. The OLS regression showed [summarize key OLS findings].\n")
cat("2. The quantile regression revealed heterogeneity in effects across the distribution, with [summarize variation in coefficients across quantiles].\n")
cat("3. The interaction effects indicated [summarize key interaction findings].\n")
cat("4. The pseudo RÂ˛ values suggest that the model explains [interpret goodness of fit].\n\n")
cat("These findings highlight the value of quantile regression in providing a more comprehensive understanding of the relationships beyond what traditional mean-based regression methods offer.\n")
# Limitations and future directions
cat("## Limitations and Future Directions\n\n")
cat("Several limitations should be noted:\n\n")
cat("1. The analysis assumes [state assumptions].\n")
cat("2. The quantile regression approach used here does not account for [mention any limitations].\n")
cat("3. Future research could extend this analysis by [suggest improvements].\n")
# References
cat("## References\n\n")
cat("- Koenker, R., & Bassett, G. (1978). Regression quantiles. Econometrica, 46(1), 33-50.\n")
cat("- Hao, L., & Naiman, D. Q. (2007). Quantile regression. Sage Publications.\n")
cat("- Koenker, R. (2005). Quantile regression. Cambridge University Press.\n")
